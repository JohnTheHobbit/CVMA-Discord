# Discord Bot
DISCORD_TOKEN=your-bot-token-here
DISCORD_CLIENT_ID=your-client-id-here
DISCORD_GUILD_ID=your-guild-id-here

# AirTable
AIRTABLE_API_KEY=pat.your-personal-access-token
AIRTABLE_BASE_ID=appYourBaseId
AIRTABLE_TABLE_NAME=Members

# SMTP (Email Verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=bot@yourdomain.com
SMTP_PASS=your-google-app-password
SMTP_FROM=CVMA MN Bot <bot@yourdomain.com>

# Sync Schedule (cron expression — default: every 6 hours)
SYNC_CRON=0 */6 * * *

# Logging
LOG_LEVEL=info
